{
  "keyboard_name": "xiao_macropad",
  "maintainer": "kavin",
  "processor": "RP2040",
  "bootloader": "rp2040",
  "diode_direction": "COL2ROW",
  "features": {
    "bootmagic": true,
    "command": false,
    "console": false,
    "extrakey": true,
    "mousekey": false,
    "nkro": true
  },
  "matrix_pins": {
    "direct": [["GP2", "GP4", "GP3", "GP1", "GP29"]]
  },
  "encoder": {
    "rotary": [
      {
        "pin_a": "GP27",
        "pin_b": "GP28"
      }
    ]
  },
  "layouts": {
    "LAYOUT": {
      "layout": [
        { "label": "K00", "matrix": [0, 0], "x": 0, "y": 0 },
        { "label": "K01", "matrix": [0, 1], "x": 1, "y": 0 },
        { "label": "K02", "matrix": [0, 2], "x": 2, "y": 0 },
        { "label": "K03", "matrix": [0, 3], "x": 3, "y": 0 },
        { "label": "K04", "matrix": [0, 4], "x": 4, "y": 0 }
      ]
    }
  }
}
